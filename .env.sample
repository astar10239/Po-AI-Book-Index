# Database Configuration
DATABASE_URL=postgresql://user:pass@localhost:5432/po_app

# Redis / Celery Configuration
REDIS_URL=redis://localhost:6379

# Storage Config
UPLOAD_FOLDER=/uploads

# OpenAI Compatible API Config
OPENAI_API_BASE=
OPENAI_API_KEY=
LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3.2
VISION_MODEL_NAME=Qwen/Qwen3-VL-30B-A3B-Instruct
EMBEDDINGS_MODEL_NAME=BAAI/bge-m3

# Flask Secure Key
SECRET_KEY=super-secret-key-change-in-production

# AI Constraints
CHAT_CONTEXT_WINDOW=128000
MAX_EXTRACT_CHARS=16000